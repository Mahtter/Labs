#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/types.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>   // for close()

void error(char *msg) {
    perror(msg);
    exit(1);
}

int main(int argc, char *argv[]) {
    int sockfd, portno;
    struct sockaddr_in serv_addr;
    FILE *fp;
    char buffer[1024];

    if (argc < 4) {
        fprintf(stderr, "Usage: %s <server_ip> <port> <filename>\n", argv[0]);
        exit(1);
    }

    portno = atoi(argv[2]);

    // CHANGED: use SOCK_STREAM for TCP instead of SOCK_DGRAM
    sockfd = socket(AF_INET, SOCK_STREAM, 0);
    if (sockfd < 0)
        error("ERROR opening socket");

    memset(&serv_addr, 0, sizeof(serv_addr));
    serv_addr.sin_family = AF_INET;
    serv_addr.sin_port = htons(portno);
    serv_addr.sin_addr.s_addr = inet_addr(argv[1]);

    // NEW: connect to the server (TCP requires connect)
    if (connect(sockfd, (struct sockaddr *)&serv_addr, sizeof(serv_addr)) < 0) {
        error("ERROR connecting");
    }

    fp = fopen(argv[3], "r");
    if (fp == NULL) {
        error("ERROR opening file");
    }

    printf("Sending file '%s' to %s:%d via TCP...\n", argv[3], argv[1], portno);

    while (fgets(buffer, sizeof(buffer), fp) != NULL) {
        // CHANGED: use send() instead of sendto()
        if (send(sockfd, buffer, strlen(buffer), 0) < 0) {
            error("ERROR sending data");
        }
        bzero(buffer, sizeof(buffer));
    }

    // Send an EOF marker (optional, but kept from original code)
    strcpy(buffer, "EOF");
    if (send(sockfd, buffer, strlen(buffer), 0) < 0) {
        error("ERROR sending EOF");
    }

    printf("File transfer complete.\n");

    fclose(fp);
    close(sockfd);
    return 0;
}
